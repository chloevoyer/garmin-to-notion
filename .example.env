### Authentication ###

# Your Garmin account credentials.
GARMIN_EMAIL=CHANGEME
GARMIN_PASSWORD=CHANGEME

# Your Notion API token.
NOTION_TOKEN=CHANGEME
# The ID of your Notion database for activities.
NOTION_DB_ID_ACTIVITIES=CHANGEME
# The ID of your Notion database for personal records.
NOTION_DB_ID_PR=CHANGEME
# The ID of your Notion database for steps.
NOTION_DB_ID_STEPS=CHANGEME
# The ID of your Notion database for sleep data.
NOTION_DB_ID_SLEEP=CHANGEME

### Configuration ###

# The maximum number of activities to fetch from Garmin
GARMIN_ACTIVITIES_FETCH_LIMIT=50
